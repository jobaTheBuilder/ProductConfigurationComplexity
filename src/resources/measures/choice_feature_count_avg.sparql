PREFIX : <http://www.example.org/ns#>

SELECT (AVG(?childCount) AS ?count)
WHERE {
    {
        SELECT ?feature (COUNT(?child) AS ?childCount)
        WHERE {
            ?feature a :FEATURE ;
                :has ?child .
            FILTER (?child NOT IN (:numerical_range, :textual_range))
        }
        GROUP BY ?feature
    }
}
